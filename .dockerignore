# Keep the build context small and avoid leaking local secrets into images.
.git
.github
*.md
Dockerfile*
docker-compose.yml
.env
/llmbox
# Local web toolchain output: node_modules must come from npm ci inside the
# image, and the embedded dist is built by the Dockerfile's webbuild stage —
# never taken from a local build.
web/node_modules
web/coverage
internal/hub/webdist
