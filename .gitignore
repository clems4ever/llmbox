# Local env / credentials (referenced by docker-compose.yml)
.env
.claude-config.seed.json

# VSCode configuration
.vscode/

# Claude Code config (keep locally, don't track)
.claude/
CLAUDE.md

# Per-deployment config (copy from llmbox.example.yaml)
/llmbox.yaml

# Secret files referenced by the config (never commit these)
/google-client-secret

# Built binaries
/llmbox-server
/llmbox-mcp
/llmbox-spoke
/llmbox-agent

# Coverage profile (make cover)
/coverage.out

# database
/llmbox-sessions.db*

# workspace
.workspace/

# air live-reload working dir (see .air.toml)
/tmp/
/build-errors.log
# Web app toolchain. The built dist under internal/hub/webdist is generated
# (make web) and NOT committed; only its .gitkeep is tracked so the go:embed
# pattern always matches. CI and the Dockerfile build it before compiling Go.
/web/node_modules/
/web/coverage/
/internal/hub/webdist/*
!/internal/hub/webdist/.gitkeep
