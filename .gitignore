# Local env / credentials (referenced by docker-compose.yml)
.env
.claude-config.seed.json

# VSCode configuration
.vscode/

# Claude Code config (keep locally, don't track)
.claude/
CLAUDE.md

# Per-deployment config (copy from llmbox.example.yaml)
/llmbox.yaml

# Secret files referenced by the config (never commit these)
/google-client-secret

# Built binaries
/llmbox-server
/llmbox-mcp
/llmbox-spoke

# Coverage profile (make cover)
/coverage.out

# bbolt session store (default LLMBOX_STATE_FILE)
/llmbox-sessions.db

# workspace
.workspace/