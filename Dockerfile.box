# llmbox-box — the default base image launched per sandboxed box.
#
# llmbox provides only the sandbox: this image is a minimal infrastructure base,
# and each box's actual workload is installed and started by the spoke's init
# script (llmbox-spoke --init-script) when the box boots. The image bakes in only
# what the box infrastructure itself needs:
#   - the `llmbox-guest` binary on PATH — the box entrypoint: it serves the box
#     control verbs (Init/Exec/Dial) over a Unix socket the host bind-mounts in,
#     runs the init script, and proxies published ports,
#   - tini, used as PID 1 so orphaned descendants of the workload are reaped
#     instead of piling up as zombies,
#   - curl, so init scripts can fetch what they need and drive the box-port API
#     (`curl --unix-socket /run/llmbox/boxapi.sock`),
#   - util-linux and /bin/sh for general box tooling,
#   - the public CA-certificate bundle, so HTTPS calls from inside the box
#     succeed. Plain debian:bookworm-slim ships WITHOUT ca-certificates, which
#     leaves the trust store empty and makes every TLS call fail with
#     "certificate signed by unknown authority"; this image adds it.
#
# To give boxes more tooling (a language runtime, a specific application, …),
# either install it from the init script at boot, or build your own image FROM
# this one (or any glibc base meeting the requirements above) and point the
# spoke's box image at it.
#
# Build:  docker build -f Dockerfile.box -t llmbox-box .

# ---- guest build stage ----
# Build the static llmbox-guest binary (the box entrypoint) from this repo.
FROM golang:1.26-bookworm AS guest
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -o /opt/llmbox/llmbox-guest ./cmd/llmbox-guest

# ---- box image ----
FROM debian:bookworm-slim
# curl is a runtime tool: init scripts use it to fetch their workload, and the
# box-port API is driven with `curl --unix-socket /run/llmbox/boxapi.sock`.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl util-linux tini \
    && rm -rf /var/lib/apt/lists/*
# The guest on PATH so the entrypoint can invoke it directly.
COPY --from=guest /opt/llmbox/llmbox-guest /usr/local/bin/llmbox-guest
# HOME=/root and WORKDIR=/workspace are forced by the provisioner.
RUN mkdir -p /workspace

WORKDIR /workspace
# Default entrypoint for standalone runs; the llmbox provisioner overrides this
# with the same command plus an explicit --socket path.
ENTRYPOINT ["tini", "-g", "--", "llmbox-guest"]
