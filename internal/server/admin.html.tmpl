<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<title>llmbox admin</title>
<style>
  :root {
    --accent: #d97757;
    --accent-strong: #c2410c;
    --bg: #f6f5f2;
    --card: #ffffff;
    --ink: #1f2328;
    --muted: #6b7280;
    --line: #e7e5e0;
    --ok: #1a7f37;
    --err: #b42318;
    --info: #3a4cc4;
    --ok-bg: #eaf6ec;
    --err-bg: #fdeceb;
    --info-bg: #eef0fd;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1a1916; --card: #242220; --ink: #ececec; --muted: #a1a1aa;
      --line: #38352f; --ok-bg: #16271a; --err-bg: #2a1614;
      --info: #aab8ff; --info-bg: #20243a;
    }
  }
  * { box-sizing: border-box; }
  body {
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    background: var(--bg); color: var(--ink); line-height: 1.55; margin: 0;
    min-height: 100vh; padding: 1.5rem;
  }
  .wrap { max-width: 64rem; margin: 0 auto; }
  .brand { display: flex; align-items: center; gap: .6rem; margin-bottom: 1.25rem; }
  .brand .logo { width: 1.7rem; height: 1.7rem; flex: none; display: block; }
  .brand b { font-size: 1.05rem; letter-spacing: -.01em; }
  .brand .who { margin-left: auto; color: var(--muted); font-size: .85rem; }
  h1 { font-size: 1.5rem; line-height: 1.2; margin: 0 0 1.25rem; letter-spacing: -.02em; }
  .card {
    background: var(--card); border: 1px solid var(--line); border-radius: 14px;
    padding: 1.25rem 1.35rem; margin-bottom: 1.25rem; box-shadow: 0 6px 24px rgba(0,0,0,.05);
  }
  .card h2 { font-size: 1.05rem; margin: 0 0 .9rem; letter-spacing: -.01em; }
  .card h3 { font-size: .9rem; margin: 1.2rem 0 .6rem; color: var(--muted); font-weight: 600; }
  table { width: 100%; border-collapse: collapse; font-size: .9rem; }
  th, td { text-align: left; padding: .55rem .6rem; border-bottom: 1px solid var(--line); vertical-align: middle; }
  th { color: var(--muted); font-weight: 600; font-size: .78rem; text-transform: uppercase; letter-spacing: .03em; }
  tr:last-child td { border-bottom: 0; }
  td.mono, .mono { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
  .empty { color: var(--muted); font-size: .9rem; padding: .4rem 0; }
  .pill { display: inline-block; padding: .12rem .5rem; border-radius: 999px; font-size: .76rem; font-weight: 600; }
  .pill.on { background: var(--ok-bg); color: var(--ok); }
  .pill.off { background: var(--err-bg); color: var(--err); }
  .pill.muted { background: var(--info-bg); color: var(--info); }
  form.inline { display: inline; }
  form.row { display: flex; flex-wrap: wrap; gap: .6rem; align-items: flex-end; margin-top: 1rem; }
  .field { display: flex; flex-direction: column; gap: .25rem; }
  .field label { font-size: .76rem; color: var(--muted); font-weight: 600; }
  input[type=text], select {
    padding: .5rem .6rem; font-size: .92rem; border: 1px solid var(--line);
    border-radius: 8px; background: var(--bg); color: var(--ink); min-width: 9rem;
  }
  input[type=text]:focus, select:focus { outline: 2px solid var(--accent); outline-offset: 1px; border-color: var(--accent); }
  button {
    padding: .5rem .95rem; font-size: .9rem; font-weight: 600; color: #fff; background: var(--accent);
    border: 0; border-radius: 8px; cursor: pointer;
  }
  button:hover { background: var(--accent-strong); }
  button.danger { background: transparent; color: var(--err); border: 1px solid var(--line); padding: .35rem .7rem; font-size: .82rem; }
  button.danger:hover { background: var(--err-bg); }
  .btn-link {
    display: inline-block; padding: .6rem 1.1rem; background: var(--accent); color: #fff;
    text-decoration: none; border-radius: 8px; font-weight: 600; font-size: .92rem; margin-bottom: .6rem;
  }
  .btn-link:hover { background: var(--accent-strong); }
  .banner { padding: .8rem 1rem; border-radius: 10px; font-size: .92rem; margin-bottom: 1.25rem; }
  .banner.ok { background: var(--ok-bg); color: var(--ok); }
  .banner.err { background: var(--err-bg); color: var(--err); }
  .result { background: var(--info-bg); border-radius: 10px; padding: .9rem 1rem; margin-bottom: 1rem; }
  .result .label { font-size: .76rem; color: var(--muted); text-transform: uppercase; letter-spacing: .03em; margin: .6rem 0 .2rem; }
  .result .val { word-break: break-all; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: .88rem; }
  .result a { color: var(--accent-strong); }
  .note { color: var(--muted); font-size: .82rem; margin: .4rem 0 0; }
</style>
</head>
<body>
<div class="wrap">
  <div class="brand">
    <img class="logo" src="/favicon.svg" width="27" height="27" alt=""><b>llmbox</b>
    {{if .SignedIn}}<span class="who">Signed in as {{.Email}}</span>{{end}}
  </div>

{{if not .SignedIn}}
  <div class="card">
    <h1>Admin sign-in</h1>
    <p class="note">Sign in to manage cluster spokes and boxes.</p>
    {{range .SignIn}}
      <a class="btn-link" style="display:block;text-align:center" href="{{.LoginPath}}">Sign in with {{.Label}}</a>
    {{else}}
      <div class="banner err">No sign-in providers are configured.</div>
    {{end}}
  </div>
{{else if .NotAdmin}}
  <div class="card">
    <h1>Not authorized</h1>
    <div class="banner err">You're signed in as {{.Email}}, but that account isn't an administrator.</div>
    <p class="note">Ask an administrator to add your address to <span class="mono">auth.admin.emails</span>.</p>
  </div>
{{else}}
  <h1>Cluster admin</h1>

  {{if .Flash}}<div class="banner {{if .FlashOK}}ok{{else}}err{{end}}">{{.Flash}}</div>{{end}}

  {{if .NewSpoke}}
  <div class="result">
    <strong>Join token for spoke "{{.NewSpoke.Name}}" — one-time use, shown once.</strong>
    <div class="label">Token</div>
    <div class="val">{{.NewSpoke.Token}}</div>
    <div class="label">Start the spoke with</div>
    <div class="val">{{.NewSpoke.Command}}</div>
    <p class="note">Persist the spoke's <span class="mono">--state</span> file (e.g. a mounted volume) so it can reconnect without this one-time token.</p>
  </div>
  {{end}}

  {{if .NewBox}}
  <div class="result">
    <strong>Box "{{.NewBox.BoxID}}" created on spoke "{{.NewBox.Spoke}}".</strong>
    <div class="label">Activation URL (open to finish sign-in)</div>
    <div class="val"><a href="{{.NewBox.AuthURL}}" target="_blank" rel="noopener noreferrer">{{.NewBox.AuthURL}}</a></div>
  </div>
  {{end}}

  <div class="card">
    <h2>Spokes</h2>
    <table>
      <thead><tr><th>Name</th><th>Status</th><th>Enrolled</th><th></th></tr></thead>
      <tbody>
      {{range .Spokes}}
        <tr>
          <td class="mono">{{.Name}}</td>
          <td>{{if .Connected}}<span class="pill on">connected</span>{{else}}<span class="pill off">offline</span>{{end}}</td>
          <td class="mono">{{if .Local}}—{{else}}{{.EnrolledAt.Format "2006-01-02 15:04"}}{{end}}</td>
          <td>
            {{if not .Local}}
            <form class="inline" method="post" action="/admin/spokes/delete" onsubmit="return confirm('Drop spoke {{.Name}} and kick its connection?')">
              <input type="hidden" name="csrf" value="{{$.CSRF}}">
              <input type="hidden" name="name" value="{{.Name}}">
              <button class="danger" type="submit">Drop</button>
            </form>
            {{end}}
          </td>
        </tr>
      {{else}}
        <tr><td colspan="4" class="empty">No spokes.</td></tr>
      {{end}}
      </tbody>
    </table>

    <form class="row" method="post" action="/admin/spokes">
      <input type="hidden" name="csrf" value="{{.CSRF}}">
      <div class="field"><label>Spoke name</label><input type="text" name="name" placeholder="edge-1" autocomplete="off" required></div>
      <div class="field"><label>Token TTL</label><input type="text" name="ttl" placeholder="1h" autocomplete="off"></div>
      <button type="submit">Create spoke token</button>
    </form>

    {{if .Tokens}}
    <h3>Outstanding join tokens</h3>
    <table>
      <thead><tr><th>ID</th><th>Spoke</th><th>Expires</th><th></th></tr></thead>
      <tbody>
      {{range .Tokens}}
        <tr>
          <td class="mono">{{.Short}}</td>
          <td class="mono">{{.Name}}</td>
          <td class="mono">{{.Expires}}{{if .Expired}} <span class="pill off">expired</span>{{end}}</td>
          <td>
            <form class="inline" method="post" action="/admin/tokens/delete">
              <input type="hidden" name="csrf" value="{{$.CSRF}}">
              <input type="hidden" name="id" value="{{.ID}}">
              <button class="danger" type="submit">Revoke</button>
            </form>
          </td>
        </tr>
      {{end}}
      </tbody>
    </table>
    {{end}}
  </div>

  <div class="card">
    <h2>Boxes</h2>
    <table>
      <thead><tr><th>Box ID</th><th>Spoke</th><th>Image</th><th>State</th><th>Phase</th><th>Created</th><th></th></tr></thead>
      <tbody>
      {{range .Boxes}}
        <tr>
          <td class="mono">{{.BoxID}}</td>
          <td class="mono">{{.Spoke}}</td>
          <td class="mono">{{.Image}}</td>
          <td>{{.State}}</td>
          <td>{{if eq .Phase "ready"}}<span class="pill on">ready</span>{{else}}<span class="pill muted">{{.Phase}}</span>{{end}}</td>
          <td class="mono">{{.Created}}</td>
          <td>
            <form class="inline" method="post" action="/admin/boxes/delete" onsubmit="return confirm('Remove box {{.BoxID}}?')">
              <input type="hidden" name="csrf" value="{{$.CSRF}}">
              <input type="hidden" name="box_id" value="{{.BoxID}}">
              <button class="danger" type="submit">Remove</button>
            </form>
          </td>
        </tr>
      {{else}}
        <tr><td colspan="7" class="empty">No boxes.</td></tr>
      {{end}}
      </tbody>
    </table>

    <form class="row" method="post" action="/admin/boxes">
      <input type="hidden" name="csrf" value="{{.CSRF}}">
      <div class="field"><label>Box ID</label><input type="text" name="box_id" placeholder="refactor-auth" autocomplete="off" required></div>
      <div class="field"><label>Image (optional)</label><input type="text" name="image" placeholder="default" autocomplete="off"></div>
      <div class="field"><label>Description (optional)</label><input type="text" name="description" autocomplete="off"></div>
      <div class="field"><label>Spoke</label>
        <select name="spoke">
          <option value="local">local</option>
          {{range .ConnectedSpokes}}<option value="{{.}}">{{.}}</option>{{end}}
        </select>
      </div>
      <button type="submit">Create box</button>
    </form>
  </div>
{{end}}
</div>
</body>
</html>
