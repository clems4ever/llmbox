<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<title>Sign in to llmbox</title>
<style>
  :root {
    --accent: #d97757;
    --accent-strong: #c2410c;
    --bg: #f6f5f2;
    --card: #ffffff;
    --ink: #1f2328;
    --muted: #6b7280;
    --line: #e7e5e0;
    --err: #b42318;
    --err-bg: #fdeceb;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1a1916; --card: #242220; --ink: #ececec; --muted: #a1a1aa;
      --line: #38352f; --err-bg: #2a1614;
    }
  }
  * { box-sizing: border-box; }
  body {
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    background: var(--bg); color: var(--ink); line-height: 1.55; margin: 0;
    min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 1.5rem;
  }
  .card {
    background: var(--card); width: 100%; max-width: 30rem; border: 1px solid var(--line);
    border-radius: 16px; padding: 2rem 2rem 1.75rem; box-shadow: 0 10px 40px rgba(0,0,0,.08);
  }
  .brand { display: flex; align-items: center; gap: .6rem; margin-bottom: 1.25rem; }
  .brand .logo { width: 1.7rem; height: 1.7rem; flex: none; display: block; }
  .brand b { font-size: 1.05rem; letter-spacing: -.01em; }
  h1 { font-size: 1.4rem; line-height: 1.25; margin: 0 0 .35rem; letter-spacing: -.02em; }
  .lead { color: var(--muted); margin: 0 0 1.5rem; text-align: justify; }
  .btn-link {
    display: block; text-align: center; padding: .7rem 1.1rem; margin-bottom: .6rem;
    background: var(--accent); color: #fff; text-decoration: none; border-radius: 8px;
    font-weight: 600; font-size: .92rem;
  }
  .btn-link:hover { background: var(--accent-strong); }
  .note { color: var(--muted); font-size: .82rem; margin: .6rem 0 0; text-align: justify; }
  .banner { padding: .8rem 1rem; border-radius: 10px; font-size: .92rem; }
  .banner.err { background: var(--err-bg); color: var(--err); }
  @media (max-width: 30rem) {
    body { padding: 0; align-items: stretch; }
    .card {
      max-width: none; min-height: 100vh;
      border: 0; border-radius: 0; box-shadow: none;
      padding: 1.75rem 1.25rem;
    }
  }
</style>
</head>
<body>
<main class="card">
  <div class="brand"><img class="logo" src="/favicon.svg" width="27" height="27" alt=""><b>llmbox</b></div>
  <h1>Sign in</h1>
  {{if .Providers}}
  <p class="lead">Sign in to continue to this workspace.</p>
  {{range .Providers}}
  <a class="btn-link" href="{{.LoginPath}}">Sign in with {{.Label}}</a>
  {{end}}
  <p class="note">You'll be returned to the page you were visiting once you're signed in.</p>
  {{else}}
  <div class="banner err">No valid destination to sign in for. Open the workspace's link directly.</div>
  {{end}}
</main>
</body>
</html>
