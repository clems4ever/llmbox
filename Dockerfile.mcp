# llmbox-mcp — stand-alone MCP server that forwards to an upstream llmbox server.
#
# It serves the llmbox MCP tools and forwards every call to an upstream llmbox
# server's box-control API (mcp_addr) over HTTP. It holds no Docker, session, or
# cluster state of its own and needs no Docker socket — it is a thin protocol
# adapter, deployable wherever a chatbot needs an MCP endpoint.
#
# Build:
#   docker build -f Dockerfile.mcp -t llmbox-mcp .
#
# Run (streamable HTTP on 8081, forwarding to the llmbox server's box-control API):
#   docker run --rm -p 8081:8081 \
#     llmbox-mcp --upstream http://llmbox:8081 --addr :8081
#
# Or over stdio (for a chatbot that launches it as a child process):
#   docker run --rm -i llmbox-mcp --stdio --upstream http://llmbox:8081

# ---- build stage ----
FROM golang:1.26-bookworm AS build

WORKDIR /src

# Cache dependencies first (copy just the module files so this layer stays
# cacheable across source-only changes).
COPY go.mod go.sum ./
RUN go mod download

# Build a static binary so it runs on a distroless base.
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build \
    -trimpath -ldflags="-s -w" \
    -o /out/llmbox-mcp ./cmd/llmbox-mcp

# ---- runtime stage ----
FROM gcr.io/distroless/static-debian12:nonroot

# 8081 = streamable-HTTP MCP endpoint (ignored when run with --stdio).
EXPOSE 8081

COPY --from=build /out/llmbox-mcp /usr/local/bin/llmbox-mcp

ENTRYPOINT ["/usr/local/bin/llmbox-mcp"]
