# Claude Code in Remote Control mode, on a general-purpose Debian dev image.
#
# Runs `claude remote-control` (server mode) so you can drive this local
# session from claude.ai/code or the Claude mobile app. The process stays
# in the foreground waiting for remote connections; only outbound HTTPS
# (port 443) is used — no inbound ports are opened.
#
# The image is a standard Debian (bookworm) with a batteries-included
# toolchain so the sandboxed Claude can build and run code: git, Python,
# Node.js, Go, and Rust are all preinstalled and on PATH.
#
# Auth: Remote Control requires a claude.ai subscription and a full-scope
# OAuth token. API keys (ANTHROPIC_API_KEY) are NOT supported.
#
# This image reuses the credentials from an already-authenticated host
# install by bind-mounting ~/.claude/.credentials.json into the container.
# The container's `node` user is UID 1000 (matching a typical Linux host
# user), so the mount stays writable and Claude can persist refreshed
# tokens back to the host file.
#
# Build:
#   docker build -t claude-remote -f Dockerfile.claude .
#
# Run (mount your project + host credentials, read-write):
#   docker run --rm -it \
#     -v "$HOME/.claude/.credentials.json":/home/node/.claude/.credentials.json \
#     -v "$PWD":/workspace \
#     claude-remote
#
# Alternative — pass a token explicitly instead of mounting credentials:
#   docker run --rm -it -e CLAUDE_CODE_OAUTH_TOKEN="$TOKEN" -v "$PWD":/workspace claude-remote

FROM debian:bookworm-slim

ARG NODE_MAJOR=22
ENV DEBIAN_FRONTEND=noninteractive

# Base tooling and the Python toolchain.
#   git           — Claude Code repo features (and --spawn=worktree)
#   ca-certificates / curl / wget — outbound HTTPS + toolchain downloads
#   iputils-ping / netcat-openbsd — network reachability debugging (e.g. to the
#                   peer servers wired into the box's network)
#   build-essential — C toolchain that Rust/cgo need to link
#   python3 + pip + venv, python-is-python3 — `python` resolves to Python 3
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        wget \
        iputils-ping \
        netcat-openbsd \
        git \
        sudo \
        build-essential \
        python3 \
        python3-pip \
        python3-venv \
        python-is-python3 \
    && rm -rf /var/lib/apt/lists/*

# Node.js via NodeSource — Claude Code needs a modern Node runtime, newer
# than the one in Debian's repositories.
RUN curl -fsSL "https://deb.nodesource.com/setup_${NODE_MAJOR}.x" | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Go — official tarball into /usr/local/go. The version is resolved to the
# current stable release at build time so the image stays up to date.
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
        amd64) goarch=amd64 ;; \
        arm64) goarch=arm64 ;; \
        *) echo "unsupported architecture: $arch" >&2; exit 1 ;; \
    esac; \
    go_version="$(curl -fsSL 'https://go.dev/VERSION?m=text' | head -n1)"; \
    curl -fsSL "https://go.dev/dl/${go_version}.linux-${goarch}.tar.gz" -o /tmp/go.tgz; \
    tar -C /usr/local -xzf /tmp/go.tgz; \
    rm /tmp/go.tgz
ENV PATH="/usr/local/go/bin:${PATH}"

# Rust — installed system-wide via rustup so every user can use it. Toolchain
# lives in /usr/local/{rustup,cargo}; cargo's bin dir is added to PATH.
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH="/usr/local/cargo/bin:/usr/local/go/bin:${PATH}"
RUN curl -fsSL https://sh.rustup.rs | sh -s -- -y --no-modify-path --profile minimal \
    && chmod -R a+w "$RUSTUP_HOME" "$CARGO_HOME"

# Install Claude Code globally. Pin a version that supports Remote Control
# (>= 2.1.51); bump as needed.
RUN npm install -g @anthropic-ai/claude-code@latest \
    && claude --version

# Sanity-check that every toolchain is on PATH.
RUN git --version && python --version && node --version \
    && go version && rustc --version && cargo --version

# Run as an unprivileged user at UID 1000 (matching a typical Linux host
# user) so a single-file credentials bind-mount stays writable. Pre-create
# ~/.claude as a home for the mount.
#
# The user gets passwordless sudo so the box can run apt-get and other root
# tasks on demand, while normal files (and the bind-mounted credentials)
# stay owned by UID 1000 rather than root.
RUN useradd --create-home --uid 1000 --shell /bin/bash node \
    && mkdir -p /home/node/.claude \
    && chown -R node:node /home/node \
    && echo 'node ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/node \
    && chmod 0440 /etc/sudoers.d/node

USER node
WORKDIR /workspace

# Optional: full-scope claude.ai OAuth token (not an API key). Leave empty
# when bind-mounting ~/.claude/.credentials.json instead.
ENV CLAUDE_CODE_OAUTH_TOKEN=""

# Server mode: stays running, accepts remote sessions, prints a session
# URL/QR code in the logs. Tune via CLAUDE_REMOTE_ARGS, e.g.
#   -e CLAUDE_REMOTE_ARGS="--name codespec --spawn worktree --capacity 8"
ENV CLAUDE_REMOTE_ARGS=""

# `claude remote-control` only fully connects (and registers the environment
# with the backend) when stdout is an interactive TTY. Under `docker compose
# up -d` there is no attached terminal, so we wrap it in `script` to allocate
# a real PTY inside the container — otherwise it takes a degraded path, never
# reaches "Ready", and the session never shows up in claude.ai/code.
# Output (including the Environment ID + session URL) is streamed to the
# container logs.
ENTRYPOINT ["/bin/sh", "-c", "exec script -qfc \"claude remote-control $CLAUDE_REMOTE_ARGS\" /dev/null"]
